# Copy to .env and fill in real values. NEVER commit .env.

# Database — PostgreSQL everywhere (Neon). For local dev, use a Neon dev
# branch or a local Postgres instance.
# Neon format: postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# JWT — REQUIRED. Generate with: openssl rand -base64 48
JWT_SECRET=

# Paystack (https://dashboard.paystack.com)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Public site URL (used for Paystack callback)
NEXT_PUBLIC_SITE_URL=http://localhost:4028
NEXT_PUBLIC_API_URL=http://localhost:4028/api

# Seed admin (used by prisma/seed.ts; required in production)
SEED_ADMIN_EMAIL=admin@247sparkle.com
SEED_ADMIN_PASSWORD=

# Google Maps (optional)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
